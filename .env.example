# Application Environment
NODE_ENV=development
COMPOSE_PROJECT_NAME=nestjs-enterprise-dev
PORT=3000

# Docker Container Configuration
# Name your containers for easy identification in docker ps
APP_CONTAINER_NAME=app_dev
POSTGRES_CONTAINER_NAME=postgres_dev
REDIS_CONTAINER_NAME=redis_dev
POSTGRES_VOLUME_NAME=postgres_dev_data
REDIS_VOLUME_NAME=redis_dev_data

# Database Configuration
# POSTGRES_HOST: hostname where postgres is running (use 'postgres' for Docker containers)
# POSTGRES_PORT: port where postgres listens
# POSTGRES_BIND_HOST: bind address for external access (localhost=127.0.0.1 only, 0.0.0.0 for all interfaces)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_BIND_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-secure-password!
POSTGRES_DB=nestjs_db
DATABASE_URL="postgresql://postgres:change-me-secure-password!@localhost:5432/nestjs_db?schema=public"

# Redis Configuration
# REDIS_HOST: hostname where redis is running
# REDIS_PORT: port where redis listens
# REDIS_BIND_HOST: bind address for external access
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password!
REDIS_DB=0
REDIS_TTL=3600
REDIS_MAX_MEMORY=128mb

# Application Configuration
APP_NAME="NestJS Enterprise API"
APP_VERSION=1.0.0
API_PREFIX=api/v1

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# JWT Configuration
JWT_SECRET=change-me-at-least-32-chars-long-1234567890!
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-refresh-at-least-32-chars-long!
JWT_REFRESH_EXPIRES_IN=30d

# Encryption
IMAGE_ENCRYPTION_KEY=change-me-exactly-32-chars-key-00000!

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DEST=./uploads
UPLOAD_PROVIDER=local

# Swagger/Documentation
SWAGGER_ENABLED=true
SWAGGER_TITLE="NestJS Enterprise API"
SWAGGER_PATH=docs

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs
