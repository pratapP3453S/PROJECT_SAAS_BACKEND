# ==============================================================================
# ENTERPRISE APPLICATION ENVIRONMENT CONFIGURATION
# ==============================================================================
# This configuration file defines the environment variables required for the
# operation of the NestJS Enterprise application. It covers database connections,
# caching, security parameters, and application-specific settings.
#
# IMPORTANT SECURITY NOTICE:
# - NEVER commit files containing actual secrets (e.g., .env, .env.local) to version control.
# - The .env.example file serves as a safe template. All secret values must be masked.
# - Ensure that staging and production environments utilize strong, cryptographically
#   secure values for all secrets, passwords, and keys.
# ==============================================================================

# ------------------------------------------------------------------------------
# [1] APPLICATION ENVIRONMENT
# ------------------------------------------------------------------------------
# Defines the core operational context of the application.
# NODE_ENV: Determines runtime behavior (allowed: development, staging, production)
# COMPOSE_PROJECT_NAME: Namespaces Docker resources to prevent collisions
# PORT: The internal port the Node.js application binds to inside the container
# ------------------------------------------------------------------------------
NODE_ENV=development
COMPOSE_PROJECT_NAME=nestjs-enterprise-dev
PORT=3000

# ------------------------------------------------------------------------------
# [2] DOCKER INFRASTRUCTURE CONFIGURATION
# ------------------------------------------------------------------------------
# Identifiers for Docker containers and persistent volume claims.
# Modifying these will affect how Docker Compose addresses your infrastructure.
# ------------------------------------------------------------------------------
APP_CONTAINER_NAME=app_dev
POSTGRES_CONTAINER_NAME=postgres_dev
REDIS_CONTAINER_NAME=redis_dev
POSTGRES_VOLUME_NAME=postgres_dev_data
REDIS_VOLUME_NAME=redis_dev_data

# ------------------------------------------------------------------------------
# [3] POSTGRESQL DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
# Parameters for connecting to the primary relational database.
# POSTGRES_HOST: The hostname of the DB (use 'postgres' for internal Docker network)
# POSTGRES_PORT: Database port (default: 5432)
# POSTGRES_BIND_HOST: Host binding for port mapping (127.0.0.1 restricts to local)
# POSTGRES_USER: The privileged user role for the application schema
# DATABASE_URL: The constructed URI used by Prisma ORM for database connectivity
# ------------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-secure-password!
POSTGRES_DB=nestjs_db
DATABASE_URL="postgresql://postgres:change-me-secure-password!@localhost:5432/nestjs_db?schema=public"

# ------------------------------------------------------------------------------
# [4] REDIS CACHE CONFIGURATION
# ------------------------------------------------------------------------------
# Parameters for the Redis in-memory data store used for caching and sessions.
# REDIS_BIND_HOST: The network interface Redis is bound to
# REDIS_TTL: Default Time-To-Live for cache entries in seconds
# REDIS_MAX_MEMORY: Maximum memory allocation before eviction policies trigger
# ------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_BIND_HOST=127.0.0.1
REDIS_PASSWORD=change-me-redis-password!
REDIS_DB=0
REDIS_TTL=3600
REDIS_MAX_MEMORY=128mb

# ------------------------------------------------------------------------------
# [5] APPLICATION METADATA
# ------------------------------------------------------------------------------
# General descriptive information exposed via health checks and documentation.
# ------------------------------------------------------------------------------
APP_NAME="NestJS Enterprise API"
APP_VERSION=1.0.0
API_PREFIX=api/v1

# ------------------------------------------------------------------------------
# [6] SECURITY & CORS
# ------------------------------------------------------------------------------
# Cross-Origin Resource Sharing restrictions.
# CORS_ORIGINS: Comma-separated list of fully qualified domains permitted to access the API.
# Avoid using '*' or wildcard domains in staging/production environments.
# ------------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# ------------------------------------------------------------------------------
# [7] AUTHENTICATION & JWT (JSON WEB TOKENS)
# ------------------------------------------------------------------------------
# Cryptographic keys and expiration limits for user authentication tokens.
# JWT_SECRET: Must be a highly random string of at least 32 characters.
# JWT_REFRESH_SECRET: Used exclusively for issuing new access tokens.
# ------------------------------------------------------------------------------
JWT_SECRET=change-me-at-least-32-chars-long-1234567890!
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-refresh-at-least-32-chars-long!
JWT_REFRESH_EXPIRES_IN=30d

# ------------------------------------------------------------------------------
# [8] DATA ENCRYPTION
# ------------------------------------------------------------------------------
# Symmetric keys utilized for AES encryption of sensitive data or files at rest.
# IMAGE_ENCRYPTION_KEY: Must be EXACTLY 32 characters for AES-256 compatibility.
# ------------------------------------------------------------------------------
IMAGE_ENCRYPTION_KEY=change-me-exactly-32-chars-key-00000!

# ------------------------------------------------------------------------------
# [9] RATE LIMITING & DDOS MITIGATION
# ------------------------------------------------------------------------------
# Thresholds to prevent abuse by restricting the volume of requests per client.
# THROTTLE_TTL: The observation window in seconds.
# THROTTLE_LIMIT: Maximum allowable requests within the TTL window.
# ------------------------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ------------------------------------------------------------------------------
# [10] FILE UPLOAD MANAGEMENT — CORE
# ------------------------------------------------------------------------------
# Provider-agnostic settings consumed by UploadConfigService and Multer.
# UPLOAD_PROVIDER     : active storage backend. One of:
#                         local | s3 | cloudflare | cloudinary | imagekit | gcs | azure
# MAX_FILE_SIZE_MB    : hard upper bound on Multer payload (defence in depth).
# UPLOAD_DEST         : base path used by LocalStorageProvider (writes go to {dest}/temp & {dest}/{type}).
# UPLOAD_TEMP_RETENTION_HOURS : hours before temp/ files are eligible for cleanup.
# UPLOAD_PRESIGNED_EXPIRY     : default lifetime (seconds) for issued presigned URLs.
# UPLOAD_ENABLE_PRESIGNED_URLS: master switch for the presigned-URL endpoint.
# UPLOAD_ENABLE_ENCRYPTION    : master switch for AES-256 encryption of sensitive types.
# UPLOAD_ENABLE_AUDIT         : master switch for AuditLoggerService.
# UPLOAD_AUDIT_DESTINATION    : where AuditLoggerService persists entries (database|file|cloudwatch).
# UPLOAD_MAX_CONCURRENT       : concurrent uploads accepted per process.
# UPLOAD_MAX_RETRIES          : per-operation retry count for cloud providers.
# UPLOAD_RETRY_DELAY_MS       : exponential-backoff base delay between retries.
# UPLOAD_PUBLIC_BASE_URL      : optional CDN/origin prefix prepended to permanent URLs
#                                (e.g. https://cdn.example.com — useful when serving
#                                cloud-stored files behind a custom domain).
# ------------------------------------------------------------------------------
UPLOAD_PROVIDER=local
MAX_FILE_SIZE_MB=10
UPLOAD_DEST=./uploads
UPLOAD_TEMP_RETENTION_HOURS=24
UPLOAD_PRESIGNED_EXPIRY=3600
UPLOAD_ENABLE_PRESIGNED_URLS=true
UPLOAD_ENABLE_ENCRYPTION=true
UPLOAD_ENABLE_AUDIT=true
UPLOAD_AUDIT_DESTINATION=database
UPLOAD_MAX_CONCURRENT=5
UPLOAD_MAX_RETRIES=3
UPLOAD_RETRY_DELAY_MS=1000
UPLOAD_PUBLIC_BASE_URL=

# ------------------------------------------------------------------------------
# [10a] AWS S3 PROVIDER (UPLOAD_PROVIDER=s3)
# ------------------------------------------------------------------------------
# S3 bucket parameters. Required only when UPLOAD_PROVIDER=s3.
# AWS_S3_FORCE_PATH_STYLE : true when targeting S3-compatible services (MinIO, R2 via S3 SDK).
# AWS_S3_ENDPOINT         : optional endpoint override for S3-compatible services.
# AWS_S3_PUBLIC_URL       : optional CDN/CloudFront URL used to build returned permanent URLs.
# AWS_S3_TEMP_PREFIX/PERMANENT_PREFIX : object-key namespaces inside the bucket.
# ------------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_S3_BUCKET=change-me-bucket-name
AWS_ACCESS_KEY_ID=change-me-access-key
AWS_SECRET_ACCESS_KEY=change-me-secret-key
AWS_S3_ENDPOINT=
AWS_S3_FORCE_PATH_STYLE=false
AWS_S3_PUBLIC_URL=
AWS_S3_MAX_RETRIES=3
AWS_S3_TEMP_PREFIX=uploads/temp
AWS_S3_PERMANENT_PREFIX=uploads

# ------------------------------------------------------------------------------
# [10b] CLOUDFLARE R2 PROVIDER (UPLOAD_PROVIDER=cloudflare)
# ------------------------------------------------------------------------------
# R2 is S3-compatible. Endpoint is computed as
#   https://{CF_ACCOUNT_ID}.r2.cloudflarestorage.com   when CF_ENDPOINT is empty.
# CF_PUBLIC_URL points at your R2 public bucket (or custom domain) for serving files.
# ------------------------------------------------------------------------------
CF_ACCOUNT_ID=change-me-cloudflare-account-id
CF_ACCESS_KEY_ID=change-me-r2-access-key
CF_SECRET_ACCESS_KEY=change-me-r2-secret-key
CF_BUCKET_NAME=change-me-r2-bucket
CF_ENDPOINT=
CF_PUBLIC_URL=
CF_TEMP_PREFIX=uploads/temp
CF_PERMANENT_PREFIX=uploads

# ------------------------------------------------------------------------------
# [10c] CLOUDINARY PROVIDER (UPLOAD_PROVIDER=cloudinary)
# ------------------------------------------------------------------------------
# Cloudinary is a media-transformation CDN.
# CLOUDINARY_URL is the canonical credential (cloudinary://{key}:{secret}@{cloud_name}).
# Individual fields are accepted as fallback when CLOUDINARY_URL is not set.
# CLOUDINARY_UPLOAD_PRESET : optional unsigned preset for browser-side uploads.
# CLOUDINARY_FOLDER        : root folder under which type/* sub-folders are created.
# CLOUDINARY_USE_SIGNED    : true → server signs every upload; false → preset-only.
# ------------------------------------------------------------------------------
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=change-me-cloud-name
CLOUDINARY_API_KEY=change-me-api-key
CLOUDINARY_API_SECRET=change-me-api-secret
CLOUDINARY_FOLDER=uploads
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_USE_SIGNED=true
CLOUDINARY_SECURE=true

# ------------------------------------------------------------------------------
# [10d] IMAGEKIT PROVIDER (UPLOAD_PROVIDER=imagekit)
# ------------------------------------------------------------------------------
# ImageKit is an image CDN with HMAC-signed direct uploads.
# IMAGEKIT_URL_ENDPOINT : your delivery URL (https://ik.imagekit.io/{your_id}).
# IMAGEKIT_FOLDER       : base folder; type/ sub-folders nest under it.
# ------------------------------------------------------------------------------
IMAGEKIT_PUBLIC_KEY=change-me-public-key
IMAGEKIT_PRIVATE_KEY=change-me-private-key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/change-me
IMAGEKIT_FOLDER=uploads
IMAGEKIT_USE_UNIQUE_FILENAME=true

# ------------------------------------------------------------------------------
# [10e] GOOGLE CLOUD STORAGE PROVIDER (UPLOAD_PROVIDER=gcs)
# ------------------------------------------------------------------------------
# GCP_KEY_FILE : absolute path to the service-account JSON.
#                Leave empty when GOOGLE_APPLICATION_CREDENTIALS is set globally.
# ------------------------------------------------------------------------------
GCP_PROJECT_ID=
GCP_KEY_FILE=
GCP_BUCKET=

# ------------------------------------------------------------------------------
# [10f] AZURE BLOB STORAGE PROVIDER (UPLOAD_PROVIDER=azure)
# ------------------------------------------------------------------------------
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=

# ------------------------------------------------------------------------------
# [11] API DOCUMENTATION (SWAGGER/OPENAPI)
# ------------------------------------------------------------------------------
# Controls the availability of the interactive API documentation portal.
# SWAGGER_ENABLED: Should explicitly be set to 'false' in production environments.
# ------------------------------------------------------------------------------
SWAGGER_ENABLED=true
SWAGGER_TITLE="NestJS Enterprise API"
SWAGGER_PATH=docs

# ------------------------------------------------------------------------------
# [12] TELEMETRY & LOGGING
# ------------------------------------------------------------------------------
# Governs the verbosity and destination of application logs.
# LOG_LEVEL: error, warn, info, debug, verbose (use 'info' or 'warn' for prod).
# ------------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_DIR=./logs
